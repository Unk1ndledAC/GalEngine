{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://GalEngine.dev/schemas/ui-layout.json",
  "title": "GalEngine UI Layout",
  "description": "Custom UI layout configuration for the game interface.",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "textbox": {
      "type": "object",
      "description": "Dialogue text box settings.",
      "properties": {
        "visible": { "type": "boolean", "default": true },
        "x": { "type": "number", "default": 0 },
        "y": { "type": "number", "default": 540 },
        "width": { "type": "number", "default": 1280 },
        "height": { "type": "number", "default": 180 },
        "background": { "type": "string", "description": "Background image or color (hex)." },
        "opacity": { "type": "number", "default": 0.85 },
        "padding": { "type": "number", "default": 20 },
        "font": { "type": "string" },
        "font_size": { "type": "number", "default": 24 },
        "text_color": { "type": "string", "default": "#FFFFFF" },
        "name_x": { "type": "number" },
        "name_y": { "type": "number" },
        "name_font": { "type": "string" },
        "name_font_size": { "type": "number", "default": 20 },
        "name_color": { "type": "string", "default": "#C8C8FF" },
        "corner_radius": { "type": "number", "default": 0 }
      }
    },
    "quick_menu": {
      "type": "object",
      "description": "In-game quick action button bar.",
      "properties": {
        "visible": { "type": "boolean", "default": true },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "buttons": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": { "type": "string", "description": "Action: save, load, quick_save, quick_load, settings, flowchart, history, skip, auto, back_to_menu, quit, voice_collect" },
              "icon": { "type": "string", "description": "Icon image path." },
              "tooltip": { "type": "string", "description": "Tooltip text on hover." },
              "visible": { "type": "boolean", "default": true }
            }
          }
        },
        "icon_size": { "type": "number", "default": 32 },
        "spacing": { "type": "number", "default": 8 }
      }
    },
    "main_menu": {
      "type": "object",
      "description": "Main menu / title screen layout.",
      "properties": {
        "background": { "type": "string" },
        "background_parts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "image": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "scale": { "type": "number" }
            }
          },
          "description": "Composite background from multiple image parts."
        },
        "bgm": { "type": "string" },
        "title_text": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "font": { "type": "string" },
            "font_size": { "type": "number" },
            "color": { "type": "string" }
          }
        },
        "menu_items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": { "type": "string", "enum": ["new_game", "continue", "load", "gallery", "after_story", "settings", "quit"] },
              "text": { "type": "string" },
              "font": { "type": "string" },
              "font_size": { "type": "number" },
              "color": { "type": "string" },
              "hover_color": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "visible": { "type": "boolean", "default": true },
              "condition": { "type": "string", "description": "Flag condition to show this item." }
            }
          }
        }
      }
    },
    "settings_menu": {
      "type": "object",
      "properties": {
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "enum": ["text", "audio", "controls"] },
              "label": { "type": "string" }
            }
          }
        }
      }
    },
    "save_load_menu": {
      "type": "object",
      "properties": {
        "slots_per_page": { "type": "number", "default": 10 },
        "columns": { "type": "number", "default": 5 },
        "thumbnail_width": { "type": "number", "default": 200 },
        "thumbnail_height": { "type": "number", "default": 112 }
      }
    },
    "choice_menu": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "button_style": {
          "type": "object",
          "properties": {
            "background": { "type": "string" },
            "hover_background": { "type": "string" },
            "font": { "type": "string" },
            "font_size": { "type": "number" },
            "text_color": { "type": "string" }
          }
        },
        "spacing": { "type": "number", "default": 12 }
      }
    },
    "flowchart": {
      "type": "object",
      "properties": {
        "orientation": { "type": "string", "enum": ["vertical", "horizontal"], "default": "vertical" },
        "background": { "type": "string" },
        "node_style": {
          "type": "object",
          "properties": {
            "background": { "type": "string" },
            "current_background": { "type": "string" },
            "unlocked_background": { "type": "string" },
            "locked_background": { "type": "string" },
            "width": { "type": "number", "default": 120 },
            "height": { "type": "number", "default": 60 },
            "font_size": { "type": "number", "default": 14 }
          }
        },
        "node_spacing": { "type": "number", "default": 40 },
        "layer_spacing": { "type": "number", "default": 80 }
      }
    }
  }
}
